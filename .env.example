# Groq Cloud (optional AI advisory pass). Get a key at https://console.groq.com/
# Never commit real keys — copy this file to `.env` and fill locally.
GROQ_API_KEY=

# Node runtime environment
NODE_ENV=development

# Web server port (hosting providers usually inject PORT automatically)
PORT=3847

# Optional: override default chat model (see Groq docs)
# GROQ_MODEL=llama-3.1-8b-instant
